<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Soundbar</title>
  <link rel="icon" type="image/x-icon" href="/img/favicon.ico">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <!-- ===== HEADER ===== -->
  <header>
    <span class="logo">&#9654;&nbsp;Soundbar</span>
    <div class="header-right">
      <div class="theme-toggle" role="group" aria-label="Theme">
        <button id="theme-dark" class="active">DARK</button>
        <button id="theme-light">LIGHT</button>
      </div>
      <div class="user-info">
        <span class="username">
          <%= user %><% if (owner) { %>&nbsp;<span class="owner-badge">OWNER</span><% } %>
        </span>
        <a href="/logout" class="logout-btn">Logout</a>
      </div>
    </div>
  </header>

  <!-- ===== CONTROLS BAR ===== -->
  <div class="controls-bar">
    <div class="search-group">
      <input type="text" id="search" placeholder="Search sounds..." autocomplete="off">
    </div>
    <div class="price-badge">
      <% if (owner) { %>
        <span class="owner-free">&#9733; Owner &mdash; Free Plays</span>
      <% } else { %>
        <span class="ticket-info">
          <span id="ticket-balance"><%= tickets %></span> tickets
          &nbsp;&bull;&nbsp;
          <a href="/shop" class="shop-link">Buy more</a>
        </span>
      <% } %>
    </div>
  </div>

  <!-- ===== MAIN ===== -->
  <main>
    <div class="sound-grid">
      <!-- Buttons are dynamically loaded from the Formpix API -->
    </div>
  </main>

  <!-- ===== PAYMENT MODAL ===== -->
  <div id="pay-modal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
      <h3>Play Sound</h3>
      <p id="pay-modal-sound" class="modal-sound-name"></p>

      <!-- Two payment options -->
      <div id="no-tickets-notice" class="no-tickets-notice" style="display:none;">
        You don't have enough tickets.
        <a href="/shop" class="notice-shop-link">Buy a pack</a> or pay directly below.
      </div>
      <div class="pay-options">
        <button id="opt-tickets" class="pay-opt">
          <span class="opt-title">Use Tickets</span>
          <span id="modal-ticket-count" class="opt-sub">... tickets</span>
          <span class="opt-cost">5 per play</span>
        </button>
        <button id="opt-digi" class="pay-opt">
          <span class="opt-title">Pay Digipogs</span>
          <span class="opt-sub">flat rate</span>
          <span class="opt-cost">25 Digipogs</span>
        </button>
      </div>

      <!-- PIN (only shown in digi mode) -->
      <div id="pin-section" style="display:none;">
        <div class="modal-field">
          <label for="pay-pin">PIN</label>
          <input type="password" id="pay-pin" inputmode="numeric" maxlength="6"
            placeholder="Enter your PIN"
            oninput="this.value = this.value.replace(/[^0-9]/g, '');">
        </div>
        <label class="save-pin-row">
          <input type="checkbox" id="save-pin">
          <span>Remember PIN</span>
        </label>
      </div>

      <p id="pay-error" class="pay-error" style="display:none;"></p>
      <div class="modal-actions">
        <button id="pay-cancel" class="btn-secondary">Cancel</button>
        <button id="pay-confirm" class="btn-primary">Play</button>
      </div>
    </div>
  </div>

  <script>
    window.IS_OWNER = <%- JSON.stringify(owner) %>;
  </script>
  <script src="/js/main.js"></script>
</body>
</html>